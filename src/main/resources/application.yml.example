server:
  port: 8095

spring:
  application:
    name: ai-gateway-service

aigateway:
  llm:
    openai:
      base-url: ${OPENAI_BASE_URL:https://api.openai.com/v1}
      api-key: ${OPENAI_API_KEY:your-openai-api-key-here}
      timeout-ms: 30000
      default-model: gpt-4o-mini
  registry:
    seed-tools: []

logging:
  level:
    com.aigateway: DEBUG
