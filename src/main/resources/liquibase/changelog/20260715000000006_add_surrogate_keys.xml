<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Adds a BIGSERIAL surrogate primary key (id) to tools, agents, agent_tools,
        and agent_runs. The previous business-key PKs are demoted to UNIQUE constraints
        so existing lookups and foreign keys continue to work unchanged.
    -->

    <!-- ═══════════════════════════════════════════════════════════════
         tools
         ══════════════════════════════════════════════════════════════ -->

    <changeSet id="20260715000000006-1" author="shivam-kumar">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="tools" schemaName="aigateway" columnName="id"/></not>
        </preConditions>
        <sql>ALTER TABLE aigateway.tools DROP CONSTRAINT IF EXISTS tools_pkey;</sql>
        <addColumn tableName="tools" schemaName="aigateway">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addPrimaryKey tableName="tools" schemaName="aigateway"
                       columnNames="id" constraintName="pk_tools"/>
        <addUniqueConstraint tableName="tools" schemaName="aigateway"
                             columnNames="name" constraintName="uq_tools_name"/>
    </changeSet>

    <!-- ═══════════════════════════════════════════════════════════════
         agents
         ══════════════════════════════════════════════════════════════ -->

    <changeSet id="20260715000000006-2" author="shivam-kumar">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="agents" schemaName="aigateway" columnName="id"/></not>
        </preConditions>
        <!-- Drop FK on agent_tools first so we can touch the agents PK -->
        <sql>ALTER TABLE aigateway.agent_tools DROP CONSTRAINT IF EXISTS fk_agent_tools_agent;</sql>
        <sql>ALTER TABLE aigateway.agent_runs  DROP CONSTRAINT IF EXISTS fk_agent_runs_agent;</sql>
        <sql>ALTER TABLE aigateway.agents DROP CONSTRAINT IF EXISTS agents_pkey;</sql>
        <addColumn tableName="agents" schemaName="aigateway">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addPrimaryKey tableName="agents" schemaName="aigateway"
                       columnNames="id" constraintName="pk_agents"/>
        <addUniqueConstraint tableName="agents" schemaName="aigateway"
                             columnNames="agent_id" constraintName="uq_agents_agent_id"/>
        <!-- Restore FKs that reference agent_id (still a unique column) -->
        <addForeignKeyConstraint
                baseTableSchemaName="aigateway" baseTableName="agent_tools" baseColumnNames="agent_id"
                referencedTableSchemaName="aigateway" referencedTableName="agents" referencedColumnNames="agent_id"
                constraintName="fk_agent_tools_agent" onDelete="CASCADE"/>
        <addForeignKeyConstraint
                baseTableSchemaName="aigateway" baseTableName="agent_runs" baseColumnNames="agent_id"
                referencedTableSchemaName="aigateway" referencedTableName="agents" referencedColumnNames="agent_id"
                constraintName="fk_agent_runs_agent" onDelete="SET NULL"/>
    </changeSet>

    <!-- ═══════════════════════════════════════════════════════════════
         agent_tools
         ══════════════════════════════════════════════════════════════ -->

    <changeSet id="20260715000000006-3" author="shivam-kumar">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="agent_tools" schemaName="aigateway" columnName="id"/></not>
        </preConditions>
        <sql>ALTER TABLE aigateway.agent_tools DROP CONSTRAINT IF EXISTS pk_agent_tools;</sql>
        <addColumn tableName="agent_tools" schemaName="aigateway">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addPrimaryKey tableName="agent_tools" schemaName="aigateway"
                       columnNames="id" constraintName="pk_agent_tools"/>
        <addUniqueConstraint tableName="agent_tools" schemaName="aigateway"
                             columnNames="agent_id, tool_name" constraintName="uq_agent_tools_agent_tool"/>
    </changeSet>

    <!-- ═══════════════════════════════════════════════════════════════
         agent_runs
         ══════════════════════════════════════════════════════════════ -->

    <changeSet id="20260715000000006-4" author="shivam-kumar">
        <preConditions onFail="MARK_RAN">
            <not><columnExists tableName="agent_runs" schemaName="aigateway" columnName="id"/></not>
        </preConditions>
        <sql>ALTER TABLE aigateway.agent_runs DROP CONSTRAINT IF EXISTS agent_runs_pkey;</sql>
        <addColumn tableName="agent_runs" schemaName="aigateway">
            <column name="id" type="BIGSERIAL">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addPrimaryKey tableName="agent_runs" schemaName="aigateway"
                       columnNames="id" constraintName="pk_agent_runs"/>
        <addUniqueConstraint tableName="agent_runs" schemaName="aigateway"
                             columnNames="request_id" constraintName="uq_agent_runs_request_id"/>
    </changeSet>

</databaseChangeLog>
