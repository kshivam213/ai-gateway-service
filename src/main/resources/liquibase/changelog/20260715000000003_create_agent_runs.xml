<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        agent_runs
        ──────────
        Immutable record of every agent invocation (one row per /agents/run call).

        id              – surrogate BIGSERIAL primary key
        request_id      – unique business key; UUID propagated from the LLM response
        agent_id        – FK to agents.agent_id; SET NULL if agent is deleted
        session_id      – groups turns belonging to the same chat session
        input           – the user message that triggered the run
        response        – final assistant text returned to the caller
        tool_calls      – JSONB array: each entry has name, arguments, result
        prompt_tokens / completion_tokens / total_tokens – token counters
        latency_ms      – wall-clock time from request receipt to response sent
        iterations      – how many LLM→tool loop iterations ran
        status          – COMPLETED | FAILED | MAX_ITERATIONS_REACHED
        error_message   – populated only when status != COMPLETED
        created_at      – immutable; when the run started
    -->

    <changeSet id="20260715000000003-1" author="shivam-kumar">
        <validCheckSum>ANY</validCheckSum>
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="agent_runs" schemaName="aigateway"/></not>
        </preConditions>

        <createTable tableName="agent_runs" schemaName="aigateway">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="request_id" type="VARCHAR(128)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_agent_runs_request_id"/>
            </column>
            <column name="agent_id" type="VARCHAR(128)"/>
            <column name="session_id" type="VARCHAR(255)"/>
            <column name="input" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="response" type="TEXT"/>
            <column name="tool_calls" type="JSONB"/>
            <column name="prompt_tokens" type="INTEGER"/>
            <column name="completion_tokens" type="INTEGER"/>
            <column name="total_tokens" type="INTEGER"/>
            <column name="latency_ms" type="BIGINT"/>
            <column name="iterations" type="SMALLINT"/>
            <column name="status" type="VARCHAR(32)" defaultValue="COMPLETED">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="current_timestamp">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
                baseTableSchemaName="aigateway"
                baseTableName="agent_runs"
                baseColumnNames="agent_id"
                referencedTableSchemaName="aigateway"
                referencedTableName="agents"
                referencedColumnNames="agent_id"
                constraintName="fk_agent_runs_agent"
                onDelete="SET NULL"/>

        <createIndex indexName="idx_agent_runs_request_id" tableName="agent_runs" schemaName="aigateway">
            <column name="request_id"/>
        </createIndex>

        <createIndex indexName="idx_agent_runs_agent_id" tableName="agent_runs" schemaName="aigateway">
            <column name="agent_id"/>
        </createIndex>

        <createIndex indexName="idx_agent_runs_session_id" tableName="agent_runs" schemaName="aigateway">
            <column name="session_id"/>
        </createIndex>

        <createIndex indexName="idx_agent_runs_created_at" tableName="agent_runs" schemaName="aigateway">
            <column name="created_at"/>
        </createIndex>

        <createIndex indexName="idx_agent_runs_status" tableName="agent_runs" schemaName="aigateway">
            <column name="status"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>
